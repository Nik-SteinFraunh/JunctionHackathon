# LUMI deployment environment — fill in once, then scripts use it.
# This file is gitignored (.env is in .gitignore) and never rsynced to LUMI.

# CSC / LUMI project ID (looks like project_465001234).
# Find it with: on LUMI run `lumi-allocations`; or check the CSC invite email.
export LUMI_PROJECT_ACCOUNT=project_REPLACE_ME

# Slurm account — use SBATCH_ACCOUNT env var or pass --account="$LUMI_PROJECT_ACCOUNT" to sbatch.
# Do NOT use #SBATCH --account=${...} in scripts (shell variable expansion is unreliable in SBATCH directives).
export SBATCH_ACCOUNT="$LUMI_PROJECT_ACCOUNT"

# For script logging compatibility (some scripts reference SLURM_JOB_ACCOUNT)
export SLURM_JOB_ACCOUNT="$LUMI_PROJECT_ACCOUNT"
